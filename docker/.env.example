# =============================================================================
# GenePay Platform — Docker Compose Environment Variables
# Copy this file to .env and fill in all required values before running:
#   cp .env.example .env
#   docker compose --env-file .env up -d
# =============================================================================


# =============================================================================
# INFRASTRUCTURE — PostgreSQL (Payment Service)
# =============================================================================

# Database name, user and password
DB_NAME=genepay_db
DB_USERNAME=postgres
DB_PASSWORD=change_me_postgres_password

# Host port to expose PostgreSQL on (default: 5432)
DB_PORT=5432


# =============================================================================
# SHARED — Application Environment
# =============================================================================

# Runtime environment: development | production
APP_ENV=production

# Log level used across services: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =============================================================================
# SHARED — JWT (used by both Biometric and Payment services)
# =============================================================================

# IMPORTANT: Use a long, random, secret value in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT expiry in milliseconds (payment service)
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000


# =============================================================================
# BIOMETRIC SERVICE (Python / FastAPI)
# =============================================================================

# Enable/disable verbose debug output
MONGO_URL=your_mongo_url
MONGO_DATABASE=genepay_db
BIOMETRIC_DEBUG=False

# Face recognition — lower tolerance = stricter matching (0.0–1.0)
FACE_RECOGNITION_TOLERANCE=0.6

# Encoding model: "small" (faster, HOG) | "large" (accurate, CNN)
FACE_ENCODING_MODEL=large

# Minimum face size in pixels
MIN_FACE_SIZE=100

# Liveness detection
ENABLE_LIVENESS_DETECTION=False
LIVENESS_THRESHOLD=0.7
LIVENESS_MIN_SHARPNESS=50.0
LIVENESS_MIN_BRIGHTNESS=40.0
LIVENESS_MAX_BRIGHTNESS=220.0

# Maximum upload size in MB
MAX_IMAGE_SIZE_MB=5

# CORS origins allowed by the biometric service ("*" = all)
BIOMETRIC_CORS_ORIGINS=*

# External API gateway URL (used when resolving absolute URLs from biometric service)
API_GATEWAY_URL=http://localhost:80


# =============================================================================
# BLOCKCHAIN RELAY SERVICE (Node.js / Ethers.js)
# =============================================================================

# Infura (or any Ethereum JSON-RPC) endpoint for Sepolia testnet
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private key of the wallet used to submit on-chain transactions
# WARNING: never commit this value to version control
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# Deployed GenePay smart contract address on the target network
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Target network name: sepolia | localhost | hardhat
BLOCKCHAIN_NETWORK=sepolia

# Etherscan API key (used for contract verification only)
ETHERSCAN_API_KEY=your_etherscan_api_key


# =============================================================================
# PAYMENT SERVICE (Spring Boot / Java)
# =============================================================================

# Spring profile: development | production
SPRING_ENV=production

# Email / SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
# Use an App Password (not your account password) when 2-FA is enabled
MAIL_PASSWORD=your_gmail_app_password

# Sender identity shown in outgoing emails
EMAIL_FROM=noreply@genepay.com
EMAIL_FROM_NAME=GenePay
SUPPORT_EMAIL=support@genepay.com

# BioPay banking platform token (obtained after linking the platform account card)
BIOPAY_PLATFORM_TOKEN=7d2f44f9-21fb-47c5-8b73-228556f8bfb7

# External banking service base URL (if applicable)
BANKING_SERVICE_URL=http://localhost:5000

# Include blockchain audit logging
BLOCKCHAIN_ENABLED=true

# Comma-separated list of allowed CORS origins for the payment API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Login security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# Google OAuth2 (required for social sign-in)
GOOGLE_CLIENT_ID=your_google_oauth2_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth2_client_secret


# =============================================================================
# ADMIN DASHBOARD (React + Nginx)
# =============================================================================

# Base URL of the Payment Service API reachable from the browser
# In a local setup: http://localhost:8080/api/v1
# In production: https://api.genepay.com/api/v1
ADMIN_VITE_API_BASE=http://localhost:8080/api/v1


# =============================================================================
# BLOCKCHAIN DASHBOARD (React/TS + Nginx)
# =============================================================================
# VITE_RPC_URL is shared with the relay service — uses SEPOLIA_RPC_URL above
# VITE_CONTRACT_ADDRESS is shared with the relay service — uses CONTRACT_ADDRESS above
